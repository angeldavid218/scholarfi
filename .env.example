# Supabase (existing)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: dedicated Solana devnet RPC (Helius, QuickNode, etc.). Improves rate limits and
# subscription reliability vs the default public endpoint. If unset, clusterApiUrl('devnet') is used.
# VITE_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Solana reward mint (devnet SPL token mint pubkey)
VITE_REWARD_MINT=

# Optional display name in the UI (defaults to "Reward")
# VITE_REWARD_TOKEN_SYMBOL=SCHOL

# Treasury wallet that receives redemptions and can send test rewards (must match connected wallet for teacher send UI)
VITE_TREASURY_PUBKEY=

# Optional default institution for profile auto-link on first sync (defaults to demo school id)
# VITE_DEFAULT_INSTITUTION_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
